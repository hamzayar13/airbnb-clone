<header style="background: linear-gradient(135deg, #1A3C40 0%, #0F2D30 100%);" class="text-white p-4 shadow-lg sticky top-0 z-10">
  <nav class="container mx-auto">
    <!-- Desktop Navigation -->
    <div class="hidden md:flex md:justify-between md:items-center">
      <ul class="flex items-center flex-wrap gap-1">
        <li>
          <a
            href="/"
            style="<%= currentPage === 'index' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>"
            class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center font-semibold tracking-wide text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-1.5" style="color: #E07B45;">
              <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"/>
              <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"/>
            </svg>
            airbnb
          </a>
        </li>

        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <li>
              <a href="/homes" style="<%= currentPage === 'Home' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path d="M19.006 3.705a.75.75 0 00-.512-1.41L6 6.838V3a.75.75 0 00-.75-.75h-1.5A.75.75 0 003 3v4.93l-1.006.365a.75.75 0 00.512 1.41l16.5-6z"/>
                  <path fill-rule="evenodd" d="M3.019 11.115L18 5.667V9.09l4.006 1.456a.75.75 0 11-.512 1.41l-.494-.18v8.475h.75a.75.75 0 010 1.5H2.25a.75.75 0 010-1.5H3v-9.129l.019-.006zM18 20.25v-9.565l1.5.545v9.02H18zm-9-6a.75.75 0 00-.75.75v4.5c0 .414.336.75.75.75h3a.75.75 0 00.75-.75V15a.75.75 0 00-.75-.75H9z" clip-rule="evenodd"/>
                </svg>
                Homes
              </a>
            </li>
            <li>
              <a href="/favourites" style="<%= currentPage === 'favourites' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/>
                </svg>
                Favourites
              </a>
            </li>
            <li>
              <a href="/bookings" style="<%= currentPage === 'bookings' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd"/>
                </svg>
                Bookings
              </a>
            </li>
          <% } else { %>
            <li>
              <a href="/host/host-home-list" style="<%= currentPage === 'host-homes' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path d="M5.223 2.25c-.497 0-.974.198-1.325.55l-1.3 1.298A3.75 3.75 0 007.5 9.75c.627.47 1.406.75 2.25.75.844 0 1.624-.28 2.25-.75.626.47 1.406.75 2.25.75.844 0 1.623-.28 2.25-.75a3.75 3.75 0 004.902-5.652l-1.3-1.299a1.875 1.875 0 00-1.325-.549H5.223z"/>
                  <path fill-rule="evenodd" d="M3 20.25v-8.755c1.42.674 3.08.673 4.5 0A5.234 5.234 0 009.75 12c.804 0 1.568-.182 2.25-.506a5.234 5.234 0 002.25.506c.804 0 1.567-.182 2.25-.506 1.42.674 3.08.675 4.5.001v8.755h.75a.75.75 0 010 1.5H2.25a.75.75 0 010-1.5H3zm3-6a.75.75 0 01.75-.75h3a.75.75 0 01.75.75v3a.75.75 0 01-.75.75h-3a.75.75 0 01-.75-.75v-3zm8.25-.75a.75.75 0 00-.75.75v5.25c0 .414.336.75.75.75h3a.75.75 0 00.75-.75v-5.25a.75.75 0 00-.75-.75h-3z" clip-rule="evenodd"/>
                </svg>
                Host Homes
              </a>
            </li>
            <li>
              <a href="/host/reservations" style="<%= currentPage === 'reservations' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z"/>
                </svg>
                Reservations
              </a>
            </li>
            <li>
              <a href="/host/add-home" style="<%= currentPage === 'addHome' ? 'background-color: rgba(224,123,69,0.25); color: #F0A875;' : '' %>" class="hover:bg-white/10 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5 opacity-70">
                  <path fill-rule="evenodd" d="M12 3.75a.75.75 0 01.75.75v6.75h6.75a.75.75 0 010 1.5h-6.75v6.75a.75.75 0 01-1.5 0v-6.75H4.5a.75.75 0 010-1.5h6.75V4.5a.75.75 0 01.75-.75z" clip-rule="evenodd"/>
                </svg>
                Add Home
              </a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <ul class="flex items-center gap-2">
        <% if (!isLoggedIn) { %>
        <li>
          <a href="/signup" style="border: 1.5px solid rgba(255,255,255,0.4); <%= currentPage === 'signup' ? 'background-color: rgba(255,255,255,0.15);' : '' %>" class="hover:bg-white/15 py-2 px-4 rounded-lg transition duration-300 text-sm">
            Sign Up
          </a>
        </li>
        <li>
          <a href="/login" style="background-color: #E07B45; <%= currentPage === 'login' ? 'background-color: #C96835;' : '' %>" class="hover:opacity-90 py-2 px-4 rounded-lg transition duration-300 text-sm font-medium">
            Login
          </a>
        </li>
        <% } else { %>
        <li>
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <span style="font-size:0.75rem;color:rgba(255,255,255,0.6);">
              <% if (user) { %><%= user.firstName || user.email %><% } %>
            </span>
            <form action="/logout" method="POST">
              <button type="submit" style="background-color: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.25);" class="hover:bg-white/20 py-2 px-4 rounded-lg transition duration-300 flex items-center text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-1.5">
                  <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 006 5.25v13.5a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V15a.75.75 0 011.5 0v3.75a3 3 0 01-3 3h-6a3 3 0 01-3-3V5.25a3 3 0 013-3h6a3 3 0 013 3V9A.75.75 0 0115 9V5.25a1.5 1.5 0 00-1.5-1.5h-6zm5.03 4.72a.75.75 0 010 1.06l-1.72 1.72h10.94a.75.75 0 010 1.5H10.81l1.72 1.72a.75.75 0 11-1.06 1.06l-3-3a.75.75 0 010-1.06l3-3a.75.75 0 011.06 0z" clip-rule="evenodd"/>
                </svg>
                Logout
              </button>
            </form>
          </div>
        </li>
        <% } %>
      </ul>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden">
      <div class="flex justify-between items-center">
        <a href="/" class="flex items-center py-2 px-3 rounded-lg transition duration-300 font-semibold tracking-wide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" style="color:#E07B45;">
            <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"/>
            <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"/>
          </svg>
          <span class="ml-1">airbnb</span>
        </a>
        <button id="mobile-menu-button" class="p-2 rounded-lg hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden mt-2">
        <ul class="flex flex-col space-y-1 border-t border-white/20 pt-2 mt-2">
          <% if (isLoggedIn) { %>
            <% if (user && user.userType === 'guest') { %>
              <li><a href="/homes" style="<%= currentPage === 'Home' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Homes</a></li>
              <li><a href="/favourites" style="<%= currentPage === 'favourites' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Favourites</a></li>
              <li><a href="/bookings" style="<%= currentPage === 'bookings' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Bookings</a></li>
            <% } else { %>
              <li><a href="/host/host-home-list" style="<%= currentPage === 'host-homes' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Host Homes</a></li>
              <li><a href="/host/reservations" style="<%= currentPage === 'reservations' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Reservations</a></li>
              <li><a href="/host/add-home" style="<%= currentPage === 'addHome' ? 'background-color: rgba(224,123,69,0.2);' : '' %>" class="hover:bg-white/10 py-2 px-3 rounded-lg flex items-center text-sm">Add Home</a></li>
            <% } %>
          <li class="pt-2 border-t border-white/20 mt-2">
            <form action="/logout" method="POST">
              <button type="submit" class="hover:bg-white/10 py-2 px-3 rounded-lg w-full text-left flex items-center text-sm">Logout</button>
            </form>
          </li>
          <% } else { %>
          <li><a href="/signup" class="hover:bg-white/10 py-2 px-3 rounded-lg block text-sm">Sign Up</a></li>
          <li><a href="/login" style="background-color: #E07B45;" class="hover:opacity-90 py-2 px-3 rounded-lg block mt-2 text-sm font-medium text-center">Login</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  document.getElementById("mobile-menu-button")?.addEventListener("click", function () {
    document.getElementById("mobile-menu").classList.toggle("hidden");
  });
</script>
