<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Airbnb — Find Your Stay</title>
    <link rel="stylesheet" href="/output.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      @media (min-width: 640px) {
        .hero-section { padding: 5rem 2.5rem 3rem !important; }
        .main-section { padding: 3rem 2.5rem !important; }
        .stats-section { padding: 1.5rem 2.5rem !important; }
      }
      body { font-family: 'Lato', sans-serif; background: #F3F7F7; color: #1A2E30; margin: 0; }
      h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up   { animation: fadeUp 0.6s ease forwards; }
      .fade-up-2 { animation: fadeUp 0.6s ease 0.15s forwards; opacity: 0; }
      .fade-up-3 { animation: fadeUp 0.6s ease 0.3s forwards; opacity: 0; }
      .home-card {
        background: #ffffff;
        border: 1px solid rgba(26,62,64,0.1);
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s;
      }
      .home-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(26,62,64,0.12);
      }
      .home-card:hover .card-img { opacity: 1; transform: scale(1.04); }
      .card-img {
        width: 100%; height: 100%;
        object-fit: contain;
        opacity: 0.9;
        transition: opacity 0.3s, transform 0.4s;
        background-color: #EAF2F2;
      }
      .btn-primary {
        background: #E07B45;
        color: #ffffff;
        border: none;
        font-size: 0.72rem;
        padding: 0.5rem;
        cursor: pointer;
        flex: 1;
        text-align: center;
        text-decoration: none;
        border-radius: 4px;
        transition: background 0.2s;
      }
      .btn-primary:hover { background: #C96835; }
      .btn-outline {
        border: 1.5px solid #1A3C40;
        color: #1A3C40;
        font-size: 0.72rem;
        padding: 0.5rem;
        flex: 1;
        text-align: center;
        text-decoration: none;
        border-radius: 4px;
        transition: background 0.2s, color 0.2s;
        background: transparent;
      }
      .btn-outline:hover { background: #1A3C40; color: #fff; }
    </style>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <%- include('../partials/navbar') %>

    <!-- Hero -->
    <section class="hero-section" style="padding:3rem 1rem 2rem;max-width:72rem;margin:0 auto;width:100%;">
      <div class="fade-up">
        <span style="color:#3A7B6F;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;display:block;margin-bottom:1rem;">Welcome</span>
        <h1 style="font-size:4rem;color:#1A2E30;line-height:1.1;margin-bottom:1rem;font-weight:300;">
          Find Your <br/><em style="color:#E07B45;">Perfect Stay</em>
        </h1>
        <div style="width:3rem;height:2px;background:#3A7B6F;margin-bottom:1.5rem;"></div>
        <p style="color:#4A6568;font-size:0.9rem;max-width:28rem;line-height:1.8;">
          Discover unique homes and experiences around the world, hosted by real people who care.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="fade-up-2 stats-section" style="border-top:1px solid rgba(26,62,64,0.1);border-bottom:1px solid rgba(26,62,64,0.1);padding:1.5rem 1rem;background:rgba(255,255,255,0.6);">
      <div style="max-width:72rem;margin:0 auto;display:flex;gap:2rem;align-items:center;flex-wrap:wrap;">
        <div>
          <p style="color:#E07B45;font-size:1.5rem;font-weight:300;font-family:'Cormorant Garamond',serif;"><%= registeredHomes.length %></p>
          <p style="color:#7A9EA0;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-top:0.25rem;">Listed Properties</p>
        </div>
        <div style="width:1px;height:2rem;background:rgba(26,62,64,0.1);"></div>
        <div>
          <p style="color:#1A2E30;font-size:1.5rem;font-weight:300;font-family:'Cormorant Garamond',serif;"><%= [...new Set(registeredHomes.map(h => h.location))].length %></p>
          <p style="color:#7A9EA0;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-top:0.25rem;">Locations</p>
        </div>
        <div style="width:1px;height:2rem;background:rgba(26,62,64,0.1);"></div>
        <div>
          <p style="color:#1A2E30;font-size:1.5rem;font-weight:300;font-family:'Cormorant Garamond',serif;">24/7</p>
          <p style="color:#7A9EA0;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-top:0.25rem;">Support</p>
        </div>
      </div>
    </section>

    <!-- Properties -->
    <main class="fade-up-3 main-section" style="padding:3rem 1rem;max-width:72rem;margin:0 auto;width:100%;flex:1;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;">
        <p style="color:#9a8a72;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;">Registered Homes</p>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <% if (isLoggedIn && user && user.userType === 'host') { %>
          <div style="border:1.5px dashed rgba(44,36,22,0.15);padding:5rem 1.5rem;text-align:center;border-radius:8px;background:rgba(255,255,255,0.4);">
            <p style="font-size:3rem;color:rgba(44,36,22,0.15);margin-bottom:1rem;">⌂</p>
            <p style="color:#9a8a72;font-size:0.875rem;margin-bottom:0.5rem;">No properties listed yet</p>
            <a href="/host/add-home" style="color:#C1693A;font-size:0.8rem;text-decoration:none;">Register your first home →</a>
          </div>
        <% } else { %>
          <div style="border:1.5px dashed rgba(44,36,22,0.15);padding:5rem 1.5rem;text-align:center;border-radius:8px;background:rgba(255,255,255,0.4);">
            <p style="font-size:3rem;color:rgba(44,36,22,0.15);margin-bottom:1rem;">⌂</p>
            <p style="color:#9a8a72;font-size:0.875rem;margin-bottom:0.5rem;">No properties available</p>
          </div>
        <% } %>
      <% } else { %>
        <ul style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;list-style:none;padding:0;margin:0;">
          <% registeredHomes.forEach((home) => { %>
            <li class="home-card">
              <div style="height:200px;overflow:hidden;flex-shrink:0;background:#e8dcc8;">
                <% if (home.photo) { %>
                  <img src="/<%= home.photo %>" alt="<%= home.houseName %>" class="card-img" />
                <% } else { %>
                  <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                    <span style="color:rgba(44,36,22,0.2);font-size:2.5rem;">⌂</span>
                  </div>
                <% } %>
              </div>
              <div style="padding:1.25rem;display:flex;flex-direction:column;flex:1;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.4rem;">
                  <p style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:#1A2E30;font-weight:400;"><%= home.houseName %></p>
                  <span style="font-size:0.7rem;color:#3A7B6F;">★ <%= home.rating %></span>
                </div>
                <p style="font-size:0.75rem;color:#7A9EA0;margin-bottom:0.5rem;">📍 <%= home.location %></p>
                <p style="font-size:0.72rem;color:#4A6568;margin-bottom:0.75rem;overflow:hidden;display:-webkit-box;-webkit-box-orient:vertical;">
                  <%= home.description || 'No description available.' %>
                </p>
                <p style="font-size:0.9rem;color:#E07B45;font-family:'Cormorant Garamond',serif;margin-bottom:1rem;">
                  PKR <%= home.price %><span style="color:#7A9EA0;font-size:0.75rem;font-family:'Lato',sans-serif;">/night</span>
                </p>
                <div style="display:flex;gap:0.5rem;margin-top:auto;">
                  <a href="/homes/<%= home.id %>" class="btn-outline">View →</a>
                  <% if (!isLoggedIn || !user || user.userType !== 'host' || home.host_id !== user.id) { %>
                    <a href="/reserve/<%= home.id %>" class="btn-primary">Book</a>
                  <% } %>
                </div>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>