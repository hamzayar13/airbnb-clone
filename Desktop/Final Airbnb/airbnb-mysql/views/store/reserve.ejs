<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book <%= home.houseName %> — Airbnb</title>
    <link rel="stylesheet" href="/output.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      body { font-family: 'Lato', sans-serif; background: #f5f0e8; color: #2c2416; margin: 0; }
      h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up { animation: fadeUp 0.6s ease forwards; }
      .booking-card { background: #fff; border: 1px solid rgba(44,36,22,0.1); border-radius: 8px; padding: 2rem; }
      input[type="date"] { padding: 0.75rem; border: 1px solid rgba(44,36,22,0.2); border-radius: 4px; font-size: 1rem; }
      .btn-book { background: #c2714f; color: #fff; padding: 0.875rem 2rem; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem; }
      .btn-book:hover { background: #a85d3e; }
    </style>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <%- include('../partials/navbar') %>

    <main style="flex:1;padding:3rem 2.5rem;max-width:72rem;margin:0 auto;width:100%;">

      <a href="/homes/<%= home.id %>" style="color:#9a8a72;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;display:inline-block;margin-bottom:2.5rem;">← Back to Property</a>

      <div class="fade-up" style="margin-bottom:2rem;">
        <h1 style="font-size:2.5rem;color:#2c2416;font-weight:300;"><%= home.houseName %></h1>
        <p style="color:#9a8a72;font-size:0.9rem;">Complete your booking for this amazing property</p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;">

        <!-- Booking Form -->
        <div class="booking-card">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#2c2416;margin-bottom:1.5rem;">Booking Details</h2>
          <form action="/reserve" method="POST">
            <input type="hidden" name="homeId" value="<%= home.id %>">
            
            <div style="margin-bottom:1.5rem;">
              <label style="display:block;color:#7a6a52;font-weight:500;margin-bottom:0.5rem;">Check-in Date</label>
              <input type="date" name="check_in_date" required style="width:100%;">
            </div>

            <div style="margin-bottom:1.5rem;">
              <label style="display:block;color:#7a6a52;font-weight:500;margin-bottom:0.5rem;">Check-out Date</label>
              <input type="date" name="check_out_date" required style="width:100%;">
            </div>

            <p style="color:#9a8a72;font-size:0.9rem;margin-bottom:1.5rem;">
              💡 <strong>Price:</strong> PKR <%= home.price %> per night
            </p>

            <button type="submit" class="btn-book" style="width:100%;margin-bottom:1rem;">Confirm Booking</button>
            <a href="/homes/<%= home.id %>" style="display:block;text-align:center;color:#9a8a72;text-decoration:none;padding:0.75rem;">Cancel</a>
          </form>
        </div>

        <!-- Property Summary -->
        <div>
          <div class="booking-card" style="margin-bottom:1.5rem;">
            <h3 style="font-family:'Cormorant Garamond',serif;color:#2c2416;margin-bottom:1rem;">Property Summary</h3>
            <div style="height:200px;overflow:hidden;border-radius:4px;margin-bottom:1rem;">
              <% if (home.photo) { %>
                <img src="/<%= home.photo %>" alt="<%= home.houseName %>" style="width:100%;height:100%;object-fit:contain;background-color:#f0ebe0;">
              <% } else { %>
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#e8dcc8;">
                  <span style="color:rgba(44,36,22,0.2);font-size:2.5rem;">⌂</span>
                </div>
              <% } %>
            </div>
            <p style="color:#2c2416;font-size:0.9rem;margin-bottom:0.5rem;">📍 <%= home.location %></p>
            <p style="color:#7a6a52;font-size:0.85rem;margin-bottom:1rem;"><%= home.description || 'No description available.' %></p>
            <p style="color:#6b7c5e;font-size:0.8rem;">★ <%= home.rating %> / 5</p>
          </div>

          <div class="booking-card" style="background:#fff7f0;border-color:#c2714f;">
            <h3 style="font-family:'Cormorant Garamond',serif;color:#c2714f;margin-bottom:1rem;">Price Details</h3>
            <div style="display:flex;justify-content:space-between;margin-bottom:0.75rem;border-bottom:1px solid rgba(44,36,22,0.1);padding-bottom:0.75rem;">
              <span style="color:#7a6a52;">Price per night</span>
              <span style="color:#2c2416;font-weight:500;">PKR <%= home.price %></span>
            </div>
            <p style="color:#9a8a72;font-size:0.8rem;">Total will be calculated after selecting dates</p>
          </div>
        </div>

      </div>

    </main>

    <%- include('../partials/footer') %>

  </body>
</html>
