<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= home.houseName %> — Airbnb</title>
    <link rel="stylesheet" href="/output.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      @media (min-width: 640px) {
        .main-detail { padding: 3rem 2.5rem !important; }
      }
      @media (max-width: 639px) {
        .title-flex { flex-direction: column !important; gap: 1rem; }
        .booking-bottom { flex-direction: column !important; gap: 1rem; }
        .booking-actions { flex-direction: column !important; width: 100%; }
        .booking-actions a, .booking-actions form, .booking-actions button { width: 100%; text-align: center; }
      }
      body { font-family: 'Lato', sans-serif; background: #F3F7F7; color: #1A2E30; margin: 0; }
      h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up   { animation: fadeUp 0.6s ease forwards; }
      .fade-up-2 { animation: fadeUp 0.6s ease 0.15s forwards; opacity: 0; }
      .fade-up-3 { animation: fadeUp 0.6s ease 0.3s forwards; opacity: 0; }
      .tilt-card { transition: transform 0.1s ease; border-radius: 8px; overflow: hidden; border: 1px solid rgba(44,36,22,0.1); }
      .stat-card { background: #fff; border: 1px solid rgba(44,36,22,0.1); border-radius: 8px; padding: 1.25rem 1.5rem; transition: box-shadow 0.2s; }
      .stat-card:hover { box-shadow: 0 8px 24px rgba(44,36,22,0.08); }
    </style>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <%- include('../partials/navbar') %>

    <main class="main-detail" style="flex:1;padding:3rem 1rem;max-width:72rem;margin:0 auto;width:100%;">

      <a href="/" style="color:#7A9EA0;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;display:inline-block;margin-bottom:2.5rem;">← Back to Properties</a>

      <!-- Title -->
      <div class="fade-up" class="title-flex" style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:2.5rem;">
        <div>
          <span style="color:#6b7c5e;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;display:block;margin-bottom:0.75rem;">Property Detail</span>
          <h1 style="font-size:3rem;color:#2c2416;font-weight:300;line-height:1.1;"><%= home.houseName %></h1>
          <div style="width:2.5rem;height:2px;background:#E07B45;margin-top:1rem;"></div>
        </div>
        <div style="display:flex;gap:0.75rem;margin-top:0.5rem;">
          <span style="background:#fff;border:1px solid rgba(44,36,22,0.1);color:#6b7c5e;font-size:0.75rem;padding:0.4rem 0.875rem;border-radius:4px;">★ <%= home.rating %> / 5</span>
          <span style="background:#6b7c5e;color:#fff;font-size:0.75rem;padding:0.4rem 0.875rem;border-radius:4px;">Active</span>
        </div>
      </div>

      <!-- Image -->
      <div class="fade-up tilt-card" id="tiltCard" style="height:480px;margin-bottom:2.5rem;">
        <% if (home.photo) { %>
          <img src="/<%= home.photo %>" alt="<%= home.houseName %>" style="width:100%;height:100%;object-fit:contain;background-color:#EAF2F2;" />
        <% } else { %>
          <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#DDEAEC;">
            <span style="color:rgba(44,36,22,0.2);font-size:4rem;">⌂</span>
          </div>
        <% } %>
      </div>

      <!-- Two columns -->
      <div class="fade-up-2" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-bottom:1.5rem;">
        <!-- Description -->
        <div style="background:#fff;border:1px solid rgba(44,36,22,0.1);border-left:3px solid #C1693A;border-radius:8px;padding:1.75rem;">
          <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1rem;">About this property</p>
          <p style="color:#7a6a52;font-size:0.9rem;line-height:1.8;"><%= home.description || 'No description provided.' %></p>
        </div>
        <!-- Stats -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;">
          <div class="stat-card">
            <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Location</p>
            <p style="color:#2c2416;font-size:1rem;font-weight:300;"><%= home.location %></p>
          </div>
          <div class="stat-card">
            <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Per Night</p>
            <p style="color:#E07B45;font-size:1rem;font-family:'Cormorant Garamond',serif;">$<%= home.price %></p>
          </div>
          <div class="stat-card">
            <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Rating</p>
            <p style="color:#2c2416;font-size:1rem;font-weight:300;">★ <%= home.rating %> / 5</p>
          </div>
          <div class="stat-card">
            <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Status</p>
            <p style="color:#6b7c5e;font-size:0.875rem;">● Active</p>
          </div>
        </div>
      </div>

      <!-- Booking card -->
      <div class="fade-up-3" class="booking-bottom" style="background:#fff;border:1px solid rgba(44,36,22,0.1);border-radius:8px;padding:2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <p style="color:#9a8a72;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:0.5rem;">Reserve this property</p>
          <p style="color:#E07B45;font-size:2rem;font-family:'Cormorant Garamond',serif;font-weight:300;">$<%= home.price %><span style="color:#9a8a72;font-size:0.875rem;font-family:'Lato',sans-serif;">/night</span></p>
        </div>
       <div class="booking-actions" style="display:flex;gap:0.75rem;">
  <% if (isLoggedIn && user && user.userType === 'host' && home.host_id == user.id) { %>
  <div style="background:#EAF2F2;border:1.5px solid rgba(26,60,64,0.15);border-radius:4px;padding:0.75rem 1.5rem;color:#4A6568;font-size:0.875rem;">
    🏠 You own this property
  </div>
  <% } else { %>
  <% if (isLoggedIn && user) { %>
  <form action="/favourites" method="POST" style="display:inline;">
    <button type="submit" style="border:1.5px solid rgba(58,123,111,0.4);color:#3A7B6F;background:transparent;font-size:0.875rem;padding:0.75rem 1.5rem;cursor:pointer;border-radius:4px;transition:all 0.2s;">♡ Save</button>
    <input type="hidden" name="id" value="<%= home.id %>">
  </form>
  <% } %>
  <a href="/reserve/<%= home.id %>" style="background:#E07B45;color:#fff;font-size:0.875rem;padding:0.75rem 2rem;text-decoration:none;border-radius:4px;transition:background 0.2s;">Book Now →</a>
  <% } %>
</div>
      </div>

    </main>

    <%- include('../partials/footer') %>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const card = document.getElementById('tiltCard');
        if (!card) return;
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const rotateX = ((y - rect.height/2) / rect.height) * -6;
          const rotateY = ((x - rect.width/2) / rect.width) * 6;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.01)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.5s cubic-bezier(0.16,1,0.3,1)';
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';
        });
        card.addEventListener('mouseenter', () => { card.style.transition = 'transform 0.1s ease'; });
      });
    </script>
  </body>
</html>




