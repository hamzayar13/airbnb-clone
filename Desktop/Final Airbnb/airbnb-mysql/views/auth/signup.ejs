<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body style="background-color: #F3F7F7;">
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-12 px-4 sm:px-10 py-10 bg-white rounded-lg shadow-md max-w-lg w-full">
      <h1 style="font-family: 'Cormorant Garamond', serif; color: #2c2416; border-bottom: 3px solid #3A7B6F;" class="text-3xl font-bold mb-6 text-center pb-4">Create Your Account</h1>
      
      <form action="/signup" method="POST" class="max-w-md mx-auto">
 
        <%- include('../partials/errors') %>
        <!-- Name fields in a flex layout -->
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <div class="flex-1">
            <label for="firstName" style="color: #7a6a52;" class="block text-sm font-medium mb-2">First Name</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
                <i class="fas fa-user"></i>
              </span>
              <input
                type="text"
                id="firstName"
                name="firstName"
                placeholder="John"
                value="<%= oldInput.firstName ? oldInput.firstName : '' %>"
                style="background-color: white; border: 2px solid #d1d5db;"
                class="w-full pl-10 px-4 py-2.5 rounded-md focus:outline-none transition" 
                onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';" 
                onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
                required />
            </div>
          </div>
          
          <div class="flex-1">
            <label for="lastName" style="color: #7a6a52;" class="block text-sm font-medium mb-2">Last Name</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
                <i class="fas fa-user"></i>
              </span>
              <input
                type="text"
                id="lastName"
                name="lastName"
                value="<%= oldInput.lastName ? oldInput.lastName : '' %>"
                placeholder="Doe"
                style="background-color: white; border: 2px solid #d1d5db;"
                class="w-full pl-10 px-4 py-2.5 rounded-md focus:outline-none transition" 
                onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';" 
                onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';" />
            </div>
          </div>
        </div>
        
        <!-- Email field -->
        <div class="mb-4">
          <label for="email" style="color: #7a6a52;" class="block text-sm font-medium mb-2">Email Address</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-envelope"></i>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              value="<%= oldInput.email ? oldInput.email : '' %>"
              placeholder="your.email@example.com"
              style="background-color: white; border: 2px solid #d1d5db;"
              class="w-full pl-10 px-4 py-2.5 rounded-md focus:outline-none transition" 
              onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';" 
              onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
              required />
          </div>
        </div>
        
        <!-- Password fields -->
        <div class="mb-4">
          <label for="password" style="color: #7a6a52;" class="block text-sm font-medium mb-2">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-lock"></i>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter Your Password"
              style="background-color: white; border: 2px solid #d1d5db;"
              class="w-full pl-10 px-4 py-2.5 rounded-md focus:outline-none transition" 
              onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';" 
              onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
              required/>
          </div>
        </div>
        
        <div class="mb-6">
          <label for="confirmPassword" style="color: #7a6a52;" class="block text-sm font-medium mb-2">Confirm Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-lock"></i>
            </span>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Confirm Your Password"
              style="background-color: white; border: 2px solid #d1d5db;"
              class="w-full pl-10 px-4 py-2.5 rounded-md focus:outline-none transition" 
              onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';" 
              onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
              required/>
          </div>
        </div>

        <!-- User type selection with better styling -->
        <div class="mb-6">
          <p style="color: #7a6a52;" class="text-sm font-bold mb-3">👤 Choose Your Role:</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Guest Option -->
            <label class="cursor-pointer">
              <div class="p-4 border-4 rounded-lg hover:border-amber-600 transition" id="guestBox" style="border-color: #C1693A; background-color: #FDF6EF;">
                <input type="radio" name="userType" value="guest" id="guest" class="hidden" checked />
                <div class="text-center">
                  <div class="text-3xl mb-2">🏠</div>
                  <p class="font-bold text-gray-800">Guest</p>
                  <p class="text-xs text-gray-600">Browse & Book Homes</p>
                </div>
              </div>
            </label>

            <!-- Host Option -->
            <label class="cursor-pointer">
              <div class="p-4 border-2 border-gray-300 rounded-lg transition" id="hostBox">
                <input type="radio" name="userType" value="host" id="host" class="hidden" />
                <div class="text-center">
                  <div class="text-3xl mb-2">🏢</div>
                  <p class="font-bold text-gray-800">Host</p>
                  <p class="text-xs text-gray-600">List Your Properties</p>
                </div>
              </div>
            </label>
          </div>
        </div>

        <script>
          const guestInput = document.getElementById('guest');
          const hostInput = document.getElementById('host');
          const guestBox = document.getElementById('guestBox');
          const hostBox = document.getElementById('hostBox');

          function updateStyles() {
            if (guestInput.checked) {
              guestBox.style.borderColor = '#C1693A';
              guestBox.style.borderWidth = '4px';
              guestBox.style.backgroundColor = '#FDF6EF';
              hostBox.style.borderColor = '#d1d5db';
              hostBox.style.borderWidth = '2px';
              hostBox.style.backgroundColor = 'white';
            } else if (hostInput.checked) {
              hostBox.style.borderColor = '#C1693A';
              hostBox.style.borderWidth = '4px';
              hostBox.style.backgroundColor = '#FDF6EF';
              guestBox.style.borderColor = '#d1d5db';
              guestBox.style.borderWidth = '2px';
              guestBox.style.backgroundColor = 'white';
            }
          }

          guestInput.addEventListener('change', updateStyles);
          hostInput.addEventListener('change', updateStyles);
          document.addEventListener('DOMContentLoaded', updateStyles);
        </script>

        <!-- Terms and conditions -->
        <div class="mb-6">
          <label class="inline-flex items-center cursor-pointer">
            <input type="checkbox" name="terms" id="terms" style="accent-color: #C1693A;" class="form-checkbox" required />
            <span style="color: #7a6a52;" class="ml-2">I agree to the <a href="#" style="color: #C1693A;" class="hover:underline font-medium">terms and conditions</a></span>
          </label>
        </div> 

        <!-- Submit button with animation -->
        <button type="submit" style="background-color: #C1693A;" class="w-full text-white py-3 rounded-md hover:opacity-90 font-medium transition duration-300 flex items-center justify-center">
          <span>Register</span>
          <i class="fas fa-arrow-right ml-2"></i>
        </button>
        
        <!-- Login link -->
        <p class="text-center mt-4" style="color: #7a6a52;">
          Already have an account? <a href="/login" style="color: #C1693A;" class="hover:underline font-medium">Log in</a>
        </p>
      </form>
    </main>
  </body>
</html>