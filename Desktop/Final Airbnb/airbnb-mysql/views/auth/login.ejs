<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body style="background-color: #F3F7F7;">
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-12 px-4 sm:px-10 py-10 bg-white rounded-lg shadow-md max-w-lg w-full">
      <h1 style="font-family: 'Cormorant Garamond', serif; color: #2c2416; border-bottom: 3px solid #3A7B6F;" class="text-3xl font-bold mb-6 text-center pb-4">Welcome Back</h1>
      
      <form action="/login" method="POST" class="max-w-md mx-auto">
        <%- include('../partials/errors') %>
        
        <!-- Email field -->
        <div class="mb-5">
          <label for="email" style="color: #7a6a52;" class="block text-sm font-medium mb-1">Email Address</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-envelope"></i>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="your.email@example.com"
              value="<%= oldInput.email ? oldInput.email : '' %>"
              style="background-color: white; border: 2px solid #d1d5db;"
              class="w-full pl-10 px-4 py-3 rounded-md focus:outline-none transition"
              onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';"
              onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
              required />
          </div>
        </div>
        
        <!-- Password field -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-1">
            <label for="password" style="color: #7a6a52;" class="block text-sm font-medium">Password</label>
          </div>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-lock"></i>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter Your Password"
              style="background-color: white; border: 2px solid #d1d5db;"
              class="w-full pl-10 px-4 py-3 rounded-md focus:outline-none transition"
              onfocus="this.style.borderColor='#E07B45'; this.style.boxShadow='0 0 0 3px #E07B4540';"
              onblur="this.style.borderColor='#d1d5db'; this.style.boxShadow='none';"
              required/>
          </div>
        </div>
        
        <!-- Submit button with animation -->
        <button type="submit" style="background-color: #C1693A;" class="w-full text-white py-3 rounded-md hover:opacity-90 font-medium transition duration-300 flex items-center justify-center">
          <span>Sign In</span>
          <i class="fas fa-sign-in-alt ml-2"></i>
        </button>
        
        <!-- Sign up link -->
        <p class="text-center mt-6 text-gray-600">
          Don't have an account yet? <a href="/signup" style="color: #C1693A;" class="hover:underline font-medium">Sign up</a>
        </p>
      </form>
    </main>
  </body>
</html>