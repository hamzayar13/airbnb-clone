<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Host Homes — Airbnb</title>
    <link rel="stylesheet" href="/output.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      body { font-family: 'Lato', sans-serif; background: #F3F7F7; color: #1A2E30; margin: 0; }
      h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up { animation: fadeUp 0.6s ease forwards; }
      .fade-up-2 { animation: fadeUp 0.6s ease 0.15s forwards; opacity: 0; }
      .home-card {
        background: #fff;
        border: 1px solid rgba(26,62,64,0.1);
        border-radius: 10px;
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s;
      }
      .home-card:hover { transform: translateY(-5px); box-shadow: 0 16px 32px rgba(26,62,64,0.12); }
    </style>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <%- include('../partials/navbar') %>

    <main style="flex:1;padding:3rem 1rem;max-width:72rem;margin:0 auto;width:100%;">

      <div class="fade-up" style="margin-bottom:3rem;">
        <span style="color:#3A7B6F;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;display:block;margin-bottom:0.75rem;">Your Properties</span>
        <h1 style="font-size:3rem;color:#1A2E30;font-weight:300;">Host <em style="color:#E07B45;">Homes</em></h1>
        <div style="width:2.5rem;height:2px;background:#3A7B6F;margin-top:1rem;"></div>
      </div>

      <% if (!registeredHomes || registeredHomes.length === 0) { %>
        <div class="fade-up-2" style="border:1.5px dashed rgba(26,62,64,0.15);padding:5rem 1.5rem;text-align:center;border-radius:10px;background:rgba(255,255,255,0.5);">
          <p style="font-size:3rem;color:rgba(26,62,64,0.15);margin-bottom:1rem;">⌂</p>
          <p style="color:#7A9EA0;font-size:0.875rem;margin-bottom:1rem;">No properties listed yet</p>
          <a href="/host/add-home" style="background:#E07B45;color:#fff;font-size:0.85rem;padding:0.6rem 1.5rem;border-radius:4px;text-decoration:none;">+ Add Your First Home</a>
        </div>
      <% } else { %>
        <div class="fade-up-2" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
          <% registeredHomes.forEach(home => { %>
            <div class="home-card">
              <div style="height:220px;overflow:hidden;background:#EAF2F2;">
                <img src="/<%= home.photo %>" alt="<%= home.houseName %>" style="width:100%;height:100%;object-fit:contain;background-color:#EAF2F2;">
              </div>
              <div style="padding:1.25rem;">
                <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:0.5rem;">
                  <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:#1A2E30;margin:0;"><%= home.houseName %></h3>
                  <span style="color:#3A7B6F;font-size:0.75rem;">★ <%= home.rating %></span>
                </div>
                <p style="color:#7A9EA0;font-size:0.8rem;margin-bottom:0.75rem;">📍 <%= home.location %></p>
                <p style="color:#E07B45;font-family:'Cormorant Garamond',serif;font-size:1.1rem;margin-bottom:1.25rem;">Rs <%= home.price %><span style="color:#7A9EA0;font-size:0.75rem;font-family:'Lato',sans-serif;">/night</span></p>
                <div style="display:flex;gap:0.75rem;">
                  <a href="/host/edit-home/<%= home.id %>?editing=true" style="flex:1;text-align:center;background:#1A3C40;color:#fff;font-size:0.82rem;padding:0.55rem 1rem;border-radius:6px;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Edit</a>
                  <form action="/host/delete-home/<%= home.id %>" method="POST" style="flex:1;">
                    <button type="submit" style="width:100%;background:#fef2f2;color:#dc2626;border:1.5px solid #fecaca;font-size:0.82rem;padding:0.55rem 1rem;border-radius:6px;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background='#fef2f2'">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="fade-up-2" style="margin-top:2rem;text-align:center;">
          <a href="/host/add-home" style="display:inline-block;background:#E07B45;color:#fff;font-size:0.875rem;padding:0.75rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#C96835'" onmouseout="this.style.background='#E07B45'">+ Add New Home</a>
        </div>
      <% } %>

    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
